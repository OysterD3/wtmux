{
  "name": "wtmux",
  "version": "0.1.0",
  "description": "Coordinated git worktrees across sibling repos with symlink replication and one-shot Claude Code launch.",
  "license": "MIT",
  "author": "Oyster Lee <oysterd3@gmail.com>",
  "homepage": "https://github.com/OysterD3/wtmux#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OysterD3/wtmux.git"
  },
  "bugs": {
    "url": "https://github.com/OysterD3/wtmux/issues"
  },
  "keywords": [
    "git",
    "worktree",
    "worktrees",
    "git-worktree",
    "claude",
    "claude-code",
    "monorepo",
    "multi-repo",
    "cli",
    "add-dir",
    "coordinated-worktrees",
    "sibling-repos",
    "symlink"
  ],
  "type": "module",
  "bin": {
    "wtmux": "./dist/wtmux.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "execa": "^9.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
